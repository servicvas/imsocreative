---
interface Props {
  id: string;
  x: string;
  y: string;
  title: string;
  label?: string; // Опциональный символ (цифра, буква, иконка)
}
const { id, x, y, title, label } = Astro.props;
const anchorName = `--anchor-${id}`;
---

<button 
  class="tour-marker" 
  id={`marker-${id}`}
  interestfor={id} 
  popovertarget={id}
  popovertargetaction="show"
  style={`top: ${y}; left: ${x}; anchor-name: ${anchorName};`}
  aria-label={title}
>
  {label && <span class="marker-label">{label}</span>}
</button>

<div 
  id={id} 
  popover="hint" 
  class="tour-hint" 
  style={`position-anchor: ${anchorName};`}
  data-tour-point
>
  <div class="hint-header">
    <strong>{title}</strong>
    <button class="mobile-close" popovertarget={id} popovertargetaction="hide">✕</button>
  </div>
  <div class="hint-content">
    <slot />
  </div>
</div>

<!-- Сброса фокуса для предотвращения повторного открытия поповера при клике на крестик на мобилках -->
<script>
  document.querySelectorAll('[data-tour-point]').forEach(popover => {
    popover.addEventListener('toggle', (event: any) => {
      if (event.newState === 'closed') {
        const marker = document.getElementById(`marker-${popover.id}`);
        if (marker) (marker as HTMLElement).blur();
      }
    });
  });
</script>

<style>
	/* Маркер */
	.tour-marker {
		--tourmarker-size: 1.5rem;
    position: absolute;
    transform: translate(-50%, -50%);
    width: var(--tourmarker-size); 
    height: var(--tourmarker-size);
    border-radius: 50%;
    background: var(--color-brand-d);
    border: 4px solid var(--color-brand-s);
    color: var(--color-const-white);
    cursor: pointer;
    z-index: 10;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    touch-action: manipulation;
  }

	.marker-label {
		font-size: var(--font-size-xxxs);
    font-family: var(--font-family-secondary);
    position: relative;
    z-index: 2;
    pointer-events: none;
  }

	.tour-marker::after {
    content: "";
    position: absolute;
    top: 0; 
		left: 0; 
		width: 100%; 
		height: 100%;
    border-radius: 50%;
    box-shadow: 0 0 0 0 var(--color-brand-xxd);;
    animation: pulse 2s infinite;
  }

	@keyframes pulse {
		0% {
			box-shadow: 0 0 0 0 var(--color-brand-xxd);
		}
		70% {
			box-shadow: 0 0 0 12px rgba(0, 123, 255, 0);
		}
		100% {
			box-shadow: 0 0 0 0 rgba(0, 123, 255, 0);
		}
	}

	/* Общие настройки поповера */
	.tour-hint {
		padding: var(--space-md);
		border-radius: var(--radius-button-largest);
		@supports (corner-shape: squircle) {
			corner-shape: squircle;
		}
		background: var(--color-popover-bg-main);
		backdrop-filter: blur(8px);
		border: 1px solid var(--color-popover-border);
		box-shadow: var(--shadow-main);
		width: min(100%, 420px);
		color: var(--color-content-main);
		font-size: var(--font-size-s);
    font-family: var(--font-family-secondary);
		line-height: 1.3;
		transition:
			opacity 0.2s,
			scale 0.2s,
			transform 0.2s,
			display 0.2s allow-discrete,
			overlay 0.2s allow-discrete;
	}

	/* Отображение поповера на десктопах с помощью Anchor Position API */
	@media (width > 640px) {
		.tour-hint {
			position: absolute;
			position-area: bottom;
			position-try-options: flip-block, flip-inline, flip-block flip-inline;
			margin: var(--space-s) 0;
		}
		.tour-hint:not(:popover-open) {
			opacity: 0;
			scale: 0.9;
		}
		@starting-style {
			.tour-hint:popover-open {
				opacity: 0;
				scale: 0.9;
			}
		}
		.mobile-close {
			display: none!important;
		}
	}

	/* Отображение на мобильных в виде drawer */
	@media (width <= 640px) {
		.tour-hint {
			position: fixed;
			inset: auto 0 0 0;
			width: 100%;
			max-width: 100%;
			border-radius: var(--radius-button-largest) var(--radius-button-largest) 0 0;
			@supports (corner-shape: squircle) {
				corner-shape: squircle;
			}
			transform: translateY(0);
			position-anchor: none;
		}
		.tour-hint::backdrop {
			background: rgba(0, 0, 0, 0.5);
			backdrop-filter: blur(2px);
			opacity: 1;
			transition:
				opacity 0.3s,
				display 0.3s allow-discrete;
		}
		.tour-hint:not(:popover-open) {
			transform: translateY(100%);
		}
		.tour-hint:not(:popover-open)::backdrop {
			opacity: 0;
		}
		@starting-style {
			.tour-hint:popover-open {
				transform: translateY(100%);
			}
			.tour-hint:popover-open::backdrop {
				opacity: 0;
			}
		}
	}

	.hint-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: var(--space-s);
	}
	.mobile-close {
		background: #f0f0f0;
		border: none;
		border-radius: 50%;
		width: 32px;
		height: 32px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
	}
</style>

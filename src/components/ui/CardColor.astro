---
interface Props {
	sample?: string;
	hex?: string;
	hsb?: string;
	rgb?: string;
	oklch?: string;
}

const { sample, hex, hsb, rgb, oklch } = Astro.props;
---

<figure class="color-data">
	<div class="color-data-sample" style={`background: ${sample};`}></div>
	<figcaption class="color-data-values">
		{hex && <span data-valuetype="hex">{hex}</span>}
		{hsb && <span data-valuetype="hsb">{hsb}</span>}
		{rgb && <span data-valuetype="rgb">{rgb}</span>}
		{oklch && <span data-valuetype="oklch">{oklch}</span>}
	</figcaption>
</figure>

<style is:global>
	.color-data-description {
		font-family: var(--font-family-secondary);
		font-weight: var(--font-weight-extrabold);
	}

	.color-data {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		& .color-data-sample {
			width: 100%;
			aspect-ratio: 1 / 1;
			border-radius: var(--radius-button-xxl);
			@supports (corner-shape: squircle) {
				corner-shape: squircle;
			}
			border: 4px solid var(--color-bg-xh);
		}
		& .color-data-values {
			display: flex;
			flex-direction: column;
			gap: var(--space-xxxs);
			& > span {
				font-family: var(--font-family-secondary);
				font-size: var(--font-size-s);
				&::before {
					font-size: var(--font-size-xs);
					opacity: 0.6;
					letter-spacing: 0.2em;
				}
				&[data-valuetype="hex"] {
					&::before {
						content: "HEX: ";
					}
				}
				&[data-valuetype="hsb"] {
					&::before {
						content: "HSB: ";
					}
				}
				&[data-valuetype="rgb"] {
					&::before {
						content: "RGB: ";
					}
				}
				&[data-valuetype="oklch"] {
					&::before {
						content: "OKLCH: ";
					}
				}
				&::before {
					font-family: var(--font-family-primary);
					color: var(--color-content-xs);
				}
			}
		}
	}
</style>

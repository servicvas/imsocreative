									<picture>
										<source media="(max-width: 960px)" srcset="/assets/img/design/design-systems/pln/pln-general-new-m.webp" />
										<source media="(min-width: 961px) and (resolution: 1dppx)" srcset="/assets/img/design/design-systems/pln/pln-general-new-1x.webp" />
										<source media="(min-width: 961px) and (resolution: 2dppx), 
											(min-width: 961px) and (resolution: 3dppx),

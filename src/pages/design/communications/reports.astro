						(min-width: 961px) and (resolution: 3dppx),
						(min-width: 961px) and (resolution: 4dppx)" srcset="/assets/img/design/communications/reports/headofpskov-annualreport-2018-cover-2x.webp" />
						<img src="/assets/img/design/communications/reports/headofpskov-annualreport-2018-cover-2x.webp" class="article-img fullwidth halfspread" alt="Разворот отчёта главы города Пскова" loading="lazy" />
					</picture>
				</div>

					<source media="(min-width: 961px) and (resolution: 1dppx)" srcset="/assets/img/design/communications/values/values-memory.webp" />
					<source media="(min-width: 961px) and (resolution: 2dppx), 
					(min-width: 961px) and (resolution: 3dppx),
					(min-width: 961px) and (resolution: 4dppx)" srcset="/assets/img/design/communications//values/values-memory.webp" />
					<img src="/assets/img/design/communications/values/values-memory.webp" class="article-img fullwidth" alt="Баннер кампании «То, что нас объединяет»: «Память»" loading="lazy" />
				</picture>
				<picture>
					<source media="(max-width: 960px)" srcset="/assets/img/design/communications/values/values-labor.webp" />
					<source media="(min-width: 961px) and (resolution: 1dppx)" srcset="/assets/img/design/communications/values/values-labor.webp" />
					<source media="(min-width: 961px) and (resolution: 2dppx), 
					(min-width: 961px) and (resolution: 3dppx),
					(min-width: 961px) and (resolution: 4dppx)" srcset="/assets/img/design/communications//values/values-labor.webp" />
					<img src="/assets/img/design/communications/values/values-labor.webp" class="article-img fullwidth" alt="Баннер кампании «То, что нас объединяет»: «Труд»" loading="lazy" />
				</picture>
				<picture>

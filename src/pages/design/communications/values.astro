				</picture>
				<picture>
					<source media="(max-width: 960px)" srcset="/assets/img/design/communications/values/values-family.webp" />
					<source media="(min-width: 961px) and (resolution: 1dppx)" srcset="/assets/img/design/communications/values/values-family.webp" />
					<source media="(min-width: 961px) and (resolution: 2dppx), 
					(min-width: 961px) and (resolution: 3dppx),
					(min-width: 961px) and (resolution: 4dppx)" srcset="/assets/img/design/communications//values/values-family.webp" />
					<img src="/assets/img/design/communications/values/values-family.webp" class="article-img fullwidth" alt="Баннер кампании «То, что нас объединяет»: «Семья»" loading="lazy" />
				</picture>
			</div>
		</section>
	</section>
</LayoutArticle>

